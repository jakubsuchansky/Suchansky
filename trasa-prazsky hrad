      "source": [
        "import osmnx as ox\n",
        "import networkx as nx\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. Graf Pražského hradu\n",
        "G = ox.graph_from_address(\"Pražský hrad, Praha\", dist=400, network_type=\"walk\", simplify=True)\n",
        "\n",
        "# Bellman-Ford\n",
        "def bellman_ford(graf, start, cil):\n",
        "    uzly = list(graf.nodes)\n",
        "    hrany = [(u, v, d['length']) for u, v, d in graf.edges(data=True)]\n",
        "    dist = {u: float('inf') for u in uzly}\n",
        "    dist[start] = 0\n",
        "    odkud = {u: None for u in uzly}\n",
        "    for _ in range(len(uzly) - 1):\n",
        "        zmenilo_se = False\n",
        "        for u, v, vaha in hrany:\n",
        "            if dist[u] + vaha < dist[v]:\n",
        "                dist[v] = dist[u] + vaha\n",
        "                odkud[v] = u\n",
        "                zmenilo_se = True\n",
        "        if not zmenilo_se: break\n",
        "    cesta, uzel = [], cil\n",
        "    while uzel is not None:\n",
        "        cesta.append(uzel)\n",
        "        uzel = odkud[uzel]\n",
        "    cesta.reverse()\n",
        "    return dist[cil], cesta\n",
        "\n",
        "# Katedrála -> Zlatá ulička\n",
        "start_gps = (50.0909, 14.4005)\n",
        "cil_gps = (50.0921, 14.4038)\n",
        "\n",
        "start_node = ox.nearest_nodes(G, X=start_gps[1], Y=start_gps[0])\n",
        "cil_node = ox.nearest_nodes(G, X=cil_gps[1], Y=cil_gps[0])\n",
        "\n",
        "delka, cesta = bellman_ford(G, start_node, cil_node)\n",
        "\n",
        "# Vykreslení grafu ve vašem stylu\n",
        "fig, ax = ox.plot_graph_route(\n",
        "    G, cesta,\n",
        "    route_color=\"red\",\n",
        "    route_linewidth=5,\n",
        "    node_size=0,\n",
        "    bgcolor=\"white\",\n",
        "    edge_color=\"#999999\",\n",
        "    edge_linewidth=1,\n",
        "    show=False,\n",
        "    close=False\n",
        ")\n",
        "\n",
        "ax.set_title(f\"Trasa Pražský hrad (Bellman-Ford: {delka:.0f}m)\", fontsize=15)\n",
        "plt.show()"
      ],
